{
    "name": "Node.js",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
    
    "features": {},
  
    "forwardPorts": [5173],
    "portsAttributes": {
      "5173": {
        "label": "App Calzado",
        "onAutoForward": "notify",
        "visibility": "public"
      }
    },
  
    "postCreateCommand": "npm install",
  
    "customizations": {
      "vscode": {
        "extensions": [
          "dbaeumer.vscode-eslint"
        ]
      }
    },
  
    "remoteUser": "node"
  }
  